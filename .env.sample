# Pick one provider and uncomment its section.

# --- Azure OpenAI (default) ---
# LLM_BASE_URL=https://YOUR_RESOURCE.openai.azure.com/openai/v1
# LLM_API_KEY=your-azure-openai-key
# LLM_MODEL_NAME=gpt-5.4

# --- Ollama (local, no key needed) ---
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL_NAME=gemma4:e4b

# --- OpenAI ---
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=your-openai-api-key
# LLM_MODEL_NAME=gpt-5.4

# --- OpenRouter (uses OpenAI-compatible API) ---
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=your-openrouter-api-key
# LLM_MODEL_NAME=google/gemma-3-27b-it
